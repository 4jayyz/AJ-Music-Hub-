--// Execution Logic
local function WriteOnAllSigns()
    pcall(function()
        local commonIDs = {"211", "100", "279", "13", "126", "121", "110"}
        for _, id in pairs(commonIDs) do
            local randomMsg = Messages[math.random(1, #Messages)]
            CemeteryRemote:FireServer("ReturningBigSign3Name", tostring(id), TargetName .. " " .. randomMsg)
        end
        
        for i = 1, 300, 10 do 
            if not AutoWriteEnabled then break end
            task.spawn(function()
                for j = i, i+9 do
                    local loopMsg = Messages[math.random(1, #Messages)]
                    CemeteryRemote:FireServer("ReturningBigSign3Name", tostring(j), TargetName .. " " .. loopMsg)
                end
            end)
            task.wait(0.1) 
        end
    end)
end

-- Toggle Logic
StartToggle.MouseButton1Click:Connect(function()
    AutoWriteEnabled = not AutoWriteEnabled
    StartToggle.Text = "Start Writing: " .. (AutoWriteEnabled and "ON" or "OFF")
    StartToggle.BackgroundColor3 = AutoWriteEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
    
    if AutoWriteEnabled then
        task.spawn(function()
            while AutoWriteEnabled do
                WriteOnAllSigns()
                task.wait(WriteDelay)
            end
        end)
    end
end)

